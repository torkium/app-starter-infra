# Variables GitHub Environment
ENV_VAR__COMPOSE_PROJECT_NAME=starter
ENV_VAR__APP_DOMAIN=app.example.test
ENV_VAR__BACK_IMAGE=ghcr.io/example/starter-back
ENV_VAR__FRONT_IMAGE=ghcr.io/example/starter-front
ENV_VAR__MYSQL_VERSION=8.4.9
ENV_VAR__REDIS_VERSION=8.6.3-alpine
ENV_VAR__NGINX_VERSION=1.30.0-alpine
ENV_VAR__MERCURE_VERSION=v0.23.5
ENV_VAR__MAILPIT_VERSION=latest
ENV_VAR__GRAFANA_VERSION=13.0.1
ENV_VAR__PROMETHEUS_VERSION=v3.11.3
ENV_VAR__LOKI_VERSION=3.7.1
ENV_VAR__ALLOY_VERSION=v1.16.1
ENV_VAR__CADVISOR_VERSION=v0.55.1
ENV_VAR__MYSQL_DATABASE=app
ENV_VAR__MYSQL_USER=app
ENV_VAR__HOST_HTTP_PORT=80
ENV_VAR__HOST_HTTPS_PORT=443
ENV_VAR__MAILPIT_SMTP_PORT=1025
ENV_VAR__MAILPIT_HTTP_PORT=8025
ENV_VAR__TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
ENV_VAR__TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
ENV_VAR__BACK_HTTP_PORT=8080
ENV_VAR__BACK_HEALTH_PATH=/api/health
ENV_VAR__FRONT_HTTP_PORT=3000
ENV_VAR__MIGRATION_COMMAND=php bin/console doctrine:migrations:migrate --no-interaction
ENV_VAR__WORKER_DEFAULT_COMMAND=php bin/console messenger:consume async --time-limit=3600 --memory-limit=256M
ENV_VAR__WORKER_MAIL_COMMAND=php bin/console messenger:consume async_mail --time-limit=3600 --memory-limit=256M
ENV_VAR__WORKER_OUTBOX_COMMAND=php bin/console messenger:consume async_outbox --time-limit=3600 --memory-limit=256M
ENV_VAR__SCHEDULER_COMMAND=/usr/local/bin/scheduler-loop.sh
ENV_VAR__SCHEDULER_TICK_COMMAND=php bin/console app:schedule:run
ENV_VAR__MERCURE_CORS_ALLOWED_ORIGINS=https://app.example.test
ENV_VAR__MERCURE_PUBLISH_ALLOWED_ORIGINS=https://app.example.test
ENV_VAR__ENABLE_OBSERVABILITY=1
ENV_VAR__GRAFANA_AUTH_BASIC_REALM=AppObservability
ENV_VAR__PROMETHEUS_RETENTION=7d
ENV_VAR__LOKI_RETENTION=168h
ENV_VAR__ENABLE_MEDIA_EDGE=1
ENV_VAR__MEDIA_EDGE_BASE_URL=https://media.example.test
ENV_VAR__APP_ENV=prod
ENV_VAR__APP_DEBUG=0
ENV_VAR__APP_FRONT_BASE_URL=https://app.example.test
ENV_VAR__DEFAULT_URI=https://app.example.test
ENV_VAR__REDIS_URL=redis://redis:6379
ENV_VAR__MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages_async
ENV_VAR__MESSENGER_MAIL_TRANSPORT_DSN=redis://redis:6379/messages_mail
ENV_VAR__MESSENGER_OUTBOX_TRANSPORT_DSN=redis://redis:6379/messages_outbox
ENV_VAR__MESSENGER_FAILED_TRANSPORT_DSN=redis://redis:6379/messages_failed
ENV_VAR__MAILER_FROM=no-reply@example.test
ENV_VAR__API_BASE_URL=http://back:8080/api
ENV_VAR__NEXT_PUBLIC_APP_URL=https://app.example.test
ENV_VAR__NEXT_PUBLIC_MERCURE_URL=https://app.example.test/.well-known/mercure
ENV_VAR__NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_change_me
ENV_VAR__NEXT_PUBLIC_MEDIA_BASE_URL=https://media.example.test
ENV_VAR__NEXT_PUBLIC_MEDIA_UPLOAD_BASE_URL=https://app.example.test
ENV_VAR__NEXT_PUBLIC_VAPID_PUBLIC_KEY=
ENV_VAR__B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
ENV_VAR__B2_BUCKET=starter-private-media
ENV_VAR__B2_PREFIX=media
ENV_VAR__JWT_SECRET_KEY=/app/var/runtime/jwt/private.pem
ENV_VAR__JWT_PUBLIC_KEY=/app/var/runtime/jwt/public.pem
ENV_VAR__GRAFANA_ADMIN_USER=admin
ENV_VAR__BACK_SOURCE_REPOSITORY=owner/app-starter-back
ENV_VAR__FRONT_SOURCE_REPOSITORY=owner/app-starter-front
ENV_VAR__RELEASE_STATE_ROOT=/srv/starter/releases
ENV_VAR__DOCKER_CLEANUP_UNTIL=168h

# Secrets GitHub Environment
ENV_SECRET__APP_SECRET=change-me
ENV_SECRET__MYSQL_ROOT_PASSWORD=change-me
ENV_SECRET__MYSQL_PASSWORD=change-me
ENV_SECRET__MERCURE_JWT_SECRET=dev-mercure-jwt-secret-32-bytes-minimum
ENV_SECRET__MAILER_DSN=smtp://mailpit:1025
ENV_SECRET__JWT_PASSPHRASE=change-me
ENV_SECRET__JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\nreplace-with-your-private-key\n-----END PRIVATE KEY-----
ENV_SECRET__JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nreplace-with-your-public-key\n-----END PUBLIC KEY-----
ENV_SECRET__STRIPE_SECRET_KEY=sk_test_change_me
ENV_SECRET__STRIPE_WEBHOOK_SECRET=change-me
ENV_SECRET__GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password
ENV_SECRET__GRAFANA_SECRET_KEY=replace-with-strong-grafana-secret-key
ENV_SECRET__GRAFANA_HTPASSWD=admin:$apr1$replace$replace
